                            <i class="fa fa-trash"></i>
                        </button>
                    </div>
                    <p class="text-gray-700 whitespace-pre-line">${k.content}</p>
                </div>
            `).join('');
        }
        const calendarTitle = document.getElementById('calendar-title');
        const calendarGrid = document.getElementById('calendar-grid');
        const dailySummaryDate = document.getElementById('daily-summary-date');
        const dailyEntries = document.getElementById('daily-entries');
        const prevMonthBtn = document.getElementById('prev-month');
        const nextMonthBtn = document.getElementById('next-month');
        const overallPlanPrevMonthBtn = document.getElementById('overall-plan-prev-month');
        const overallPlanNextMonthBtn = document.getElementById('overall-plan-next-month');
        let calendarViewDate = new Date();
        let overallPlanMonthViewDate = new Date();
        let selectedCalendarDate = todayString;
        function getCalendarMonthInfo(date) {
            const year = date.getFullYear();
            const month = date.getMonth();
            const firstDay = new Date(year, month, 1);
            const lastDay = new Date(year, month + 1, 0);
            const startOffset = firstDay.getDay();
            const totalDays = lastDay.getDate();
            return { year, month, firstDay, lastDay, startOffset, totalDays };
        }
        function renderCalendar() {
            const { year, month, startOffset, totalDays } = getCalendarMonthInfo(calendarViewDate);
            const monthLabel = `${year}年${month + 1}月`;
            calendarTitle.textContent = monthLabel;
            const weekdayLabels = ['日', '一', '二', '三', '四', '五', '六'];
            const cells = [];
            weekdayLabels.forEach(label => {
                cells.push(`<div class="text-center text-xs font-semibold text-secondary py-2">${label}</div>`);
            });
            const checkins = readCheckins();
            const monthKey = `${year}-${String(month + 1).padStart(2, '0')}`;
            const monthEntries = checkins.filter(item => item.date.startsWith(monthKey));
            for (let i = 0; i < startOffset; i += 1) {
                cells.push('<div class="calendar-cell border border-gray-100 rounded-xl bg-light"></div>');
            }
            for (let day = 1; day <= totalDays; day += 1) {
                const dateValue = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
                const isSelected = dateValue === selectedCalendarDate;
                const isToday = dateValue === todayString;
                const isFuture = isFutureDate(dateValue);
                const dayEntries = monthEntries.filter(entry => entry.date === dateValue);
                const overallPlans = readOverallPlans().filter(plan => overlapsOverallPlanDate(plan, dateValue));
                const badgeHtml = [
                    ...dayEntries.slice(0, 2).map(entry => `
                        <div class="truncate rounded-lg px-2 py-0.5 text-[10px] mb-1" style="background:${projectColors[entry.project]?.bg || '#F3F4F6'}; color:${projectColors[entry.project]?.text || '#374151'};">
                            ${entry.project} ${entry.duration}分
                        </div>
                    `),
                    ...overallPlans.slice(0, 2).map(plan => `
                        <div class="truncate rounded-lg px-2 py-0.5 text-[10px] mb-1 bg-primary/10 text-primary">
                            ${plan.title}
                        </div>
                    `)
                ].slice(0, 2).join('');
                const extraCount = dayEntries.length + overallPlans.length - 2;
                const extraHtml = extraCount > 0 ? `<div class="text-[10px] text-secondary">+${extraCount}</div>` : '';
                cells.push(`
                    <button type="button" class="calendar-cell border rounded-xl p-3 text-left transition ${isSelected ? 'ring-2 ring-primary border-primary' : 'border-gray-100 hover:border-primary/40'} ${isFuture ? 'bg-light text-secondary' : 'bg-cardBg'}" data-date="${dateValue}">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-sm font-semibold ${isToday ? 'text-primary' : ''}">${day}</span>
                            ${dayEntries.length ? '<span class="text-[10px] text-secondary">' + dayEntries.length + '条记录</span>' : ''}
                        </div>
                        <div class="space-y-1">${badgeHtml}${extraHtml}</div>
                    </button>
                `);
            }
            calendarGrid.innerHTML = `
                <div class="grid grid-cols-7 gap-3 min-w-[560px]">
                    ${cells.join('')}
                </div>
            `;
            calendarGrid.querySelectorAll('[data-date]').forEach(btn => {
                btn.addEventListener('click', () => {
                    selectedCalendarDate = btn.dataset.date;
                    renderCalendar();
                    renderDailySummary();
                });
            });
        }
        function renderDailySummary() {
            const checkins = readCheckins();
            const entries = checkins.filter(item => item.date === selectedCalendarDate);
            const todos = readTodos().filter(item => item.date === selectedCalendarDate);
            const records = Storage.get('records').filter(item => item.date === selectedCalendarDate);
            const overallPlans = readOverallPlans().filter(plan => overlapsOverallPlanDate(plan, selectedCalendarDate));
            dailySummaryDate.textContent = selectedCalendarDate;

            const todoHtml = todos.length ? todos.map(todo => `
                <label class="flex items-center justify-between gap-2 rounded-xl border ${todo.completed ? 'bg-green-50 border-green-200' : 'bg-cardBg border-gray-200'} px-3 py-3 task-card">
                    <span class="flex items-center gap-2">
                        <input type="checkbox" class="h-4 w-4 rounded border-gray-300 text-primary focus:ring-primary" ${todo.completed ? 'checked' : ''} onchange="toggleTodo('${todo.id}')">
                        <span class="text-sm ${todo.completed ? 'text-secondary line-through' : 'text-gray-700'}">${escapeHtml(todo.title)}</span>
                    </span>
                    <span class="text-xs text-secondary">${todo.completed ? '已完成' : '待完成'}</span>
                </label>
            `).join('') : '<div class="text-sm text-secondary">该日期暂无待办。</div>';

            const recordHtml = records.length ? records.map(record => `
                <div class="p-4 border rounded-xl bg-light task-card">
                    <div class="flex items-center justify-between gap-2 mb-2">
                        <span class="font-medium text-gray-800">${escapeHtml(record.subject || '复盘')}</span>
                        <span class="text-xs text-secondary">${escapeHtml(record.date)}</span>
                    </div>
                    <p class="text-sm text-gray-600 whitespace-pre-line">${escapeHtml(record.detail || '')}</p>
                </div>
            `).join('') : '<div class="text-sm text-secondary">该日期暂无复习记录。</div>';

            const overallPlanHtml = overallPlans.length ? overallPlans.map(plan => `
                <div class="p-4 border rounded-xl bg-primary/5 task-card">
                    <div class="flex items-center justify-between gap-2">
                        <span class="font-medium text-gray-800">${escapeHtml(plan.title)}</span>
                        <span class="text-xs text-secondary">${plan.completed ? '已完成' : '进行中'}</span>
                    </div>
                    <p class="text-sm text-gray-600 mt-1">${escapeHtml(plan.detail || '')}</p>
                </div>
            `).join('') : '<div class="text-sm text-secondary">该日期暂无总体规划。</div>';

            dailyEntries.innerHTML = `
                <div class="space-y-4">
                    <div>
                        <div class="text-sm font-semibold text-gray-800 mb-3">当日复习记录</div>
                        ${entries.length ? entries.map(entry => `
                            <div class="p-4 border rounded-xl bg-light mb-3 task-card">
                                <div class="flex items-center justify-between gap-2">
                                    <span class="font-medium text-gray-800">${escapeHtml(entry.project)}</span>
                                    <span class="text-sm text-secondary">复习 ${entry.duration}分钟</span>
                                </div>
                                ${entry.note ? `<p class="text-sm text-gray-600 mt-2">复习内容：${escapeHtml(entry.note)}</p>` : ''}
                            </div>
                        `).join('') : '<div class="text-sm text-secondary">该日期暂无各科复习记录。</div>'}
                    </div>
                    <div>
                        <div class="text-sm font-semibold text-gray-800 mb-3">总体规划</div>
                        ${overallPlanHtml}
                    </div>
                    <div>
                        <div class="text-sm font-semibold text-gray-800 mb-3">待办完成情况</div>
                        ${todoHtml}
                    </div>
                    <div>
                        <div class="text-sm font-semibold text-gray-800 mb-3">复习复盘记录</div>
                        ${recordHtml}
                    </div>
                </div>
            `;
        }
        prevMonthBtn.addEventListener('click', () => {
            calendarViewDate = new Date(calendarViewDate.getFullYear(), calendarViewDate.getMonth() - 1, 1);
            renderCalendar();
        });
        nextMonthBtn.addEventListener('click', () => {
            calendarViewDate = new Date(calendarViewDate.getFullYear(), calendarViewDate.getMonth() + 1, 1);
            renderCalendar();
        });
        overallPlanPrevMonthBtn?.addEventListener('click', () => {
            overallPlanMonthViewDate = new Date(overallPlanMonthViewDate.getFullYear(), overallPlanMonthViewDate.getMonth() - 1, 1);
            renderOverallPlanMonthView();
        });
        overallPlanNextMonthBtn?.addEventListener('click', () => {
            overallPlanMonthViewDate = new Date(overallPlanMonthViewDate.getFullYear(), overallPlanMonthViewDate.getMonth() + 1, 1);
            renderOverallPlanMonthView();
        });
        window.deleteItem = function(type, id) {
            if (confirm('确定删除这条复习相关数据吗？删除后无法恢复')) {
                Storage.delete(type, id);
                renderPlanList();
                renderRecordList();
                renderKeywordList();
                updateStats();
                renderCalendar();
                renderDailySummary();
            }
        };
        window.onload = function() {
            selectedCalendarDate = todayString;
            todoDateInput.value = todayString;
            renderCalendar();
            renderDailySummary();
            renderPlanList();
            renderRecordList();
            renderKeywordList();
            renderEnglishWordTables();
            updateStats();
            renderExamCountdown();
            renderTodoPlanOptions();
            renderTodoList();
            renderTodoHistory();
            renderDashboardTodoPreview();
            renderOverallPlans();
            renderOverallPlanMonthView();
            setInterval(renderExamCountdown, 1000);
        };
    </script>
</body>
</html>
