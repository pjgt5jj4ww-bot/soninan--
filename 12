        function saveOverallPlans(plans) {
            Storage.set('overallPlans', plans);
        }

        function getOverallPlanDateRange(plan) {
            const startDate = plan.startTime ? plan.startTime.slice(0, 10) : (plan.completeDate || todayString);
            const endDate = plan.completeDate || startDate;
            const start = new Date(`${startDate}T00:00:00`);
            const end = new Date(`${endDate}T00:00:00`);
            const dates = [];
            const current = new Date(start);
            while (current <= end) {
                dates.push(current.toISOString().slice(0, 10));
                current.setDate(current.getDate() + 1);
            }
            return dates;
        }

        function overlapsOverallPlanDate(plan, dateString) {
            return getOverallPlanDateRange(plan).includes(dateString);
        }

        function renderOverallPlanMonthView() {
            const container = document.getElementById('overall-plan-month-view');
            const label = document.getElementById('overall-plan-month-label');
            const { year, month, startOffset, totalDays } = getCalendarMonthInfo(overallPlanMonthViewDate);
            label.textContent = `${year}年${month + 1}月`;
            const weekdayLabels = ['日', '一', '二', '三', '四', '五', '六'];
            const cells = [];
            weekdayLabels.forEach(labelItem => {
                cells.push(`<div class="text-center text-xs font-semibold text-secondary py-2">${labelItem}</div>`);
            });
            const plans = readOverallPlans().filter(item => item.completeDate || item.startTime || item.completed);
            for (let i = 0; i < startOffset; i += 1) {
                cells.push('<div class="min-h-[90px] border border-gray-100 rounded-xl bg-light"></div>');
            }
            for (let day = 1; day <= totalDays; day += 1) {
                const dateValue = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
                const dayPlans = plans.filter(plan => overlapsOverallPlanDate(plan, dateValue)).slice(0, 2);
                const badgeHtml = dayPlans.map(plan => `
                    <div class="truncate rounded-lg px-2 py-0.5 text-[10px] mb-1 bg-primary/10 text-primary">
                        ${plan.title}
                    </div>
                `).join('');
                const extraHtml = dayPlans.length < plans.filter(plan => overlapsOverallPlanDate(plan, dateValue)).length ? `<div class="text-[10px] text-secondary">+${plans.filter(plan => overlapsOverallPlanDate(plan, dateValue)).length - dayPlans.length}</div>` : '';
                cells.push(`
                    <div class="min-h-[90px] border border-gray-100 rounded-xl p-2 bg-cardBg">
                        <div class="text-sm font-semibold text-gray-800 mb-1">${day}</div>
                        <div class="space-y-1">${badgeHtml}${extraHtml}</div>
                    </div>
                `);
            }
            container.innerHTML = `<div class="grid grid-cols-7 gap-3 min-w-[560px]">${cells.join('')}</div>`;
        }

