                        </div>
                        <div class="h-2 bg-gray-200 rounded-full overflow-hidden">
                            <div class="h-full rounded-full bg-primary" style="width:${percent}%;"></div>
                        </div>
                        <div class="text-xs text-secondary mt-1">完成率 ${percent}%</div>
                    </div>
                `;
            }).join('');
