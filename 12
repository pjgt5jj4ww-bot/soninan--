            yingyu: '#0F766E',
            overall: '#8B5CF6'
        };
        // 替换原有通用项目配色，改为法硕复习分类配色
        const projectColors = {
            '刑法': { bg: '#FEE2E2', text: '#B91C1C' },
            '民法': { bg: '#DBEAFE', text: '#1D4ED8' },
            '法理学': { bg: '#FEF3C7', text: '#B45309' },
            '宪法': { bg: '#D1FAE5', text: '#047857' },
            '法制史': { bg: '#EDE9FE', text: '#7E22CE' },
            '政治': { bg: '#FFE4E6', text: '#BE123C' },
            '英语': { bg: '#CCFBF1', text: '#0F766E' },
            '真题刷题': { bg: '#FCE7F3', text: '#BE185D' },
            '主观题背诵': { bg: '#EFF6FF', text: '#4F46E5' }
        };
        document.getElementById('current-date').textContent = new Date().toLocaleDateString('zh-CN', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
            weekday: 'long'
        });
        const Storage = {
            get(key) {
                try {
                    return JSON.parse(localStorage.getItem(key)) || [];
                } catch (error) {
                    return [];
                }
            },
            set(key, data) {
                localStorage.setItem(key, JSON.stringify(data));
            },
            add(key, item) {
                const list = this.get(key);
                list.unshift(item);
                this.set(key, list);
            },
            delete(key, id) {
                const list = this.get(key).filter(item => item.id !== id);
                this.set(key, list);
            }
        };
        const getId = () => `${Date.now()}-${Math.random().toString(36).substr(2, 5)}`;
        const today = new Date();
        const todayString = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
        const examCountdown = document.getElementById('exam-countdown');
        function renderExamCountdown() {
            const examDate = new Date(new Date().getFullYear(), 11, 19, 9, 0, 0);
            const now = new Date();
            const diff = examDate - now;
            const totalSeconds = Math.max(0, Math.floor(diff / 1000));
            const days = Math.floor(totalSeconds / 86400);
            const hours = Math.floor((totalSeconds % 86400) / 3600);

            examCountdown.innerHTML = `
                <div class="min-w-[110px] rounded-xl bg-white/20 px-3 py-3 text-center">
                    <div class="text-3xl font-bold">${days}</div>
                    <div class="text-xs opacity-80 mt-1">天</div>
                </div>
                <div class="min-w-[110px] rounded-xl bg-white/20 px-3 py-3 text-center">
                    <div class="text-3xl font-bold">${hours}</div>
                    <div class="text-xs opacity-80 mt-1">小时</div>
                </div>
            `;
        }

        const navBtns = document.querySelectorAll('.nav-btn');
        const sections = document.querySelectorAll('main section');
        navBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                navBtns.forEach(b => b.classList.remove('nav-active'));
                btn.classList.add('nav-active');
                const target = btn.dataset.target;
                sections.forEach(sec => sec.classList.add('hidden'));
                document.getElementById(target).classList.remove('hidden');
            });
        });
        function formatDate(dateString) {
            return dateString.split('-').slice(1).join('/');
        }
        function normalizeCheckin(item) {
            const date = item.date || item.createdAt?.split('T')[0] || todayString;
            const duration = Number(item.duration ?? item.minutes ?? (Number(item.hours || 0) * 60));
            return {
                id: item.id || getId(),
                date,
                project: item.project || item.content || '刑法',
                duration: Number.isFinite(duration) ? duration : 0,
                note: item.note || item.content || ''
            };
        }
        function readCheckins() {
            const raw = Storage.get('checkins');
            const normalized = raw.map(normalizeCheckin).filter(item => item.date);
            if (normalized.length !== raw.length) {
                Storage.set('checkins', normalized);
            }
            return normalized;
        }
        function saveCheckin(entry) {
            const items = readCheckins();
            items.unshift(entry);
            Storage.set('checkins', items);
        }
        function getDateKey(date) {
            const d = new Date(date);
            return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
        }
        function isFutureDate(dateString) {
            const target = new Date(`${dateString}T00:00:00`);
            const todayAtMidnight = new Date(`${todayString}T00:00:00`);
            return target > todayAtMidnight;
        }
        function updateStats() {
            const checkins = readCheckins();
            const plans = Storage.get('plans');
            const uniqueDays = new Set(checkins.map(item => item.date)).size;
            document.getElementById('stat-checkin').textContent = uniqueDays;
            document.getElementById('total-days').textContent = `备考打卡天数：${uniqueDays}`;
            const finishedTasks = plans.filter(p => Number(p.progress) >= 100).length;
            document.getElementById('stat-tasks').textContent = finishedTasks;
            const totalHours = (checkins.reduce((sum, c) => sum + Number(c.duration || 0), 0) / 60).toFixed(1);
            document.getElementById('stat-hours').textContent = totalHours;
            if (plans.length) {
                const averageProgress = plans.reduce((sum, p) => sum + Number(p.progress), 0) / plans.length;
                document.getElementById('stat-tasks').textContent = `${finishedTasks} (${averageProgress.toFixed(0)}% 平均任务进度)`;
            }
        }

        function getPlanTarget(plan) {
            return Math.max(1, Number(plan.target || plan.goal || 100));
        }

        function getPlanCompletedUnits(plan) {
            return Math.max(0, Number(plan.completedUnits || plan.progress || 0));
        }

        function syncPlanProgress(planId, delta) {
            const plans = Storage.get('plans');
            const targetPlan = plans.find(item => item.id === planId);
            if (!targetPlan) {
                return;
            }
            const nextCompleted = Math.max(0, getPlanCompletedUnits(targetPlan) + delta);
            const nextTarget = getPlanTarget(targetPlan);
            const nextProgress = Math.min(100, Math.round((nextCompleted / nextTarget) * 100));
            const updatedPlans = plans.map(item => item.id === planId ? {
                ...item,
                completedUnits: nextCompleted,
                progress: nextProgress,
                target: nextTarget
            } : item);
            Storage.set('plans', updatedPlans);
        }

        function readTodos() {
            return Storage.get('todos').map(item => ({
                id: item.id || getId(),
                date: item.date || todayString,
                title: item.title || item.text || '',
                note: item.note || '',
                planId: item.planId || '',
                progressStep: Number(item.progressStep || 1),
                completed: Boolean(item.completed)
            })).filter(item => item.title);
        }

        function saveTodos(todos) {
            Storage.set('todos', todos);
        }

        function escapeHtml(value) {
            return String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
        }

        function renderDashboardTodoPreview() {
            const preview = document.getElementById('dashboard-todo-preview');
            if (!preview) {
                return;
            }
            const todos = readTodos().filter(item => item.date === todayString).sort((a, b) => Number(b.completed) - Number(a.completed));
            if (!todos.length) {
                preview.innerHTML = '<div class="text-sm text-secondary col-span-full">今日暂无待办，先去添加一条任务吧。</div>';
                return;
            }
            const completedCount = todos.filter(item => item.completed).length;
            preview.innerHTML = `
                <div class="text-sm text-secondary col-span-full mb-2">${completedCount}/${todos.length} 今日任务已完成</div>
                ${todos.slice(0, 4).map(todo => `
                    <label class="task-card flex items-center justify-between gap-2 ${todo.completed ? 'bg-green-50' : 'bg-light'}">
                        <span class="flex items-center gap-2">
                            <input type="checkbox" class="h-4 w-4 rounded border-gray-300 text-primary focus:ring-primary" ${todo.completed ? 'checked' : ''} onchange="toggleTodo('${todo.id}')">
                            <span class="text-sm ${todo.completed ? 'text-secondary line-through' : 'text-gray-800'}">${escapeHtml(todo.title)}</span>
                        </span>
                        <span class="text-xs text-secondary">+${todo.progressStep}次</span>
                    </label>
                `).join('')}
            `;
        }

        let editingTodoId = null;
        let todoEditDrafts = {};
        let editingEnglishWordId = null;
        let englishWordEditDrafts = {};

        function readEnglishWords() {
            return Storage.get('englishWords').map(item => ({
                id: item.id || getId(),
                category: item.category || 'memory',
                word: item.word || '',
                meaning: item.meaning || '',
                reviewCount: Math.max(0, Number(item.reviewCount || 0)),
                lastReviewedAt: item.lastReviewedAt || '',
                createdAt: item.createdAt || todayString
            })).filter(item => item.word && item.meaning);
        }

        function saveEnglishWords(words) {
            Storage.set('englishWords', words);
        }

        function getEnglishCategoryLabel(category) {
            const map = {
                similar: '相近词',
                confused: '易混词',
                rare: '熟词僻义',
                memory: '待记忆词'
            };
            return map[category] || '待记忆词';
        }

        function formatEnglishTime(value) {
            if (!value) {
                return '—';
            }
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) {
                return value;
            }
            return date.toLocaleString('zh-CN', { month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit' });
        }

        function renderEnglishWordTables() {
            const words = readEnglishWords();
            const categoryList = ['similar', 'confused', 'rare', 'memory'];
            categoryList.forEach(category => {
                const container = document.getElementById(`english-words-${category}`);
                const countLabel = document.getElementById(`english-count-${category}`);
                if (!container || !countLabel) {
                    return;
                }
                const items = words.filter(item => item.category === category).sort((a, b) => {
                    const reviewDiff = (a.reviewCount || 0) - (b.reviewCount || 0);
                    if (reviewDiff !== 0) {
                        return reviewDiff;
                    }
                    const at = a.lastReviewedAt ? new Date(a.lastReviewedAt).getTime() : 0;
                    const bt = b.lastReviewedAt ? new Date(b.lastReviewedAt).getTime() : 0;
                    return bt - at;
                });
                countLabel.textContent = `${items.length}词`;
                if (!items.length) {
                    container.innerHTML = '<tr><td colspan="5" class="py-6 text-sm text-secondary text-center">暂无词汇，先添加一条吧。</td></tr>';
                    return;
                }
                container.innerHTML = items.map(item => {
                    const isEditing = editingEnglishWordId === item.id;
                    const draft = englishWordEditDrafts[item.id] || {};
                    return `
                        <tr class="border-b border-gray-100">
                            <td class="py-3 pr-2">
                                ${isEditing ? `<input type="text" value="${escapeHtml(draft.word ?? item.word)}" class="w-full px-2 py-1 border rounded-lg" oninput="englishWordEditDrafts['${item.id}'].word = this.value">` : `<span class="font-medium text-gray-800">${escapeHtml(item.word)}</span>`}
                            </td>
                            <td class="py-3 pr-2">
                                ${isEditing ? `<input type="text" value="${escapeHtml(draft.meaning ?? item.meaning)}" class="w-full px-2 py-1 border rounded-lg" oninput="englishWordEditDrafts['${item.id}'].meaning = this.value">` : `<span class="text-secondary">${escapeHtml(item.meaning)}</span>`}
                            </td>
                            <td class="py-3 pr-2">
                                ${isEditing ? `<input type="number" min="0" value="${Number(draft.reviewCount ?? item.reviewCount)}" class="w-20 px-2 py-1 border rounded-lg" oninput="englishWordEditDrafts['${item.id}'].reviewCount = Number(this.value || 0)">` : `<button type="button" class="px-2 py-1 rounded-lg bg-primary/10 text-primary text-sm" onclick="incrementEnglishWordReview('${item.id}')">${item.reviewCount}</button>`}
                            </td>
                            <td class="py-3 pr-2 text-secondary">${formatEnglishTime(item.lastReviewedAt)}</td>
                            <td class="py-3">
                                ${isEditing ? `<button type="button" class="text-sm text-primary mr-2" onclick="saveEnglishWordEdit('${item.id}')">保存</button>` : `<button type="button" class="text-sm text-secondary mr-2" onclick="startEnglishWordEdit('${item.id}')">编辑</button><button type="button" class="text-sm text-danger" onclick="deleteEnglishWord('${item.id}')">删除</button>`}
                            </td>
                        </tr>
                    `;
                }).join('');
            });
        }

        function startEnglishWordEdit(id) {
            const words = readEnglishWords();
            const target = words.find(item => item.id === id);
            if (!target) {
                return;
            }
            editingEnglishWordId = id;
            englishWordEditDrafts[id] = {
                word: target.word,
                meaning: target.meaning,
                reviewCount: target.reviewCount
            };
            renderEnglishWordTables();
        }

        function saveEnglishWordEdit(id) {
            const words = readEnglishWords();
            const target = words.find(item => item.id === id);
            const draft = englishWordEditDrafts[id];
            if (!target || !draft) {
                return;
            }
            const updated = words.map(item => item.id === id ? {
                ...item,
                word: draft.word?.trim() || item.word,
                meaning: draft.meaning?.trim() || item.meaning,
                reviewCount: Math.max(0, Number(draft.reviewCount || 0))
            } : item);
            saveEnglishWords(updated);
            editingEnglishWordId = null;
            delete englishWordEditDrafts[id];
            renderEnglishWordTables();
        }

        function incrementEnglishWordReview(id) {
            const words = readEnglishWords();
            const target = words.find(item => item.id === id);
            if (!target) {
                return;
            }
            const updated = words.map(item => item.id === id ? {
                ...item,
                reviewCount: Number(item.reviewCount || 0) + 1,
                lastReviewedAt: new Date().toISOString()
            } : item);
            saveEnglishWords(updated);
            renderEnglishWordTables();
        }

        window.deleteEnglishWord = function(id) {
            const words = readEnglishWords().filter(item => item.id !== id);
            saveEnglishWords(words);
