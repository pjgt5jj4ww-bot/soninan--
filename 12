<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>法硕备考管理系统 | 法律硕士复习打卡工具</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#165DFF',
                        secondary: '#94A3B8',
                        success: '#4CAF50',
                        warning: '#FFB74D',
                        danger: '#F44336',
                        light: '#F8FAFC',
                        cardBg: '#FFFFFF',
                        law: {
                            xingfa: '#FEE2E2',
                            minfa: '#DBEAFE',
                            fali: '#FEF3C7',
                            xianfa: '#D1FAE5',
                            fazhishi: '#EDE9FE',
                            zhengzhi: '#FFE4E6',
                            yingyu: '#CCFBF1'
                        },
                        lawText: {
                            xingfa: '#B91C1C',
                            minfa: '#1D4ED8',
                            fali: '#B45309',
                            xianfa: '#047857',
                            fazhishi: '#7E22CE',
                            zhengzhi: '#BE123C',
                            yingyu: '#0F766E'
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif']
                    },
                    boxShadow: {
                        soft: '0 2px 12px rgba(0, 0, 0, 0.05)',
                        card: '0 4px 20px rgba(0, 0, 0, 0.06)',
                        float: '0 8px 24px rgba(0, 0, 0, 0.08)'
                    },
                    borderRadius: {
                        '2xl': '16px',
                        '3xl': '20px'
                    }
                }
            }
        }
    </script>
    <style type="text/tailwindcss">
        @layer utilities {
            .content-auto {
                content-visibility: auto;
            }
            .card-shadow {
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
            }
            .card-shadow-soft {
                box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
            }
            .nav-active {
                @apply bg-primary/10 text-primary rounded-xl;
            }
            .subject-active {
                @apply ring-2 ring-primary ring-offset-2;
            }
            .calendar-cell {
                min-height: 88px;
            }
            .usage-ring {
                background: conic-gradient(#165DFF 0%, #E0E7FF 0% 100%);
            }
            .task-card {
                @apply rounded-2xl p-4 card-shadow-soft transition-all hover:shadow-float hover:-translate-y-0.5;
            }
            .tag-subject {
                @apply px-2 py-0.5 rounded-lg text-xs font-medium;
            }
            .btn-primary {
                @apply px-4 py-2 rounded-xl bg-primary text-white hover:bg-primary/90 transition-all;
            }
            .btn-outline {
                @apply px-4 py-2 rounded-xl border border-gray-200 text-gray-600 hover:bg-gray-50 transition-all;
            }
            .input-base {
                @apply w-full px-4 py-2 rounded-xl border border-gray-200 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all bg-white;
            }
        }
    </style>
</head>
<body class="bg-light font-sans antialiased text-gray-800">
    <div class="min-h-screen flex flex-col">
        <!-- 顶部导航栏 轻量化 -->
        <header class="bg-cardBg card-shadow-soft sticky top-0 z-50">
            <div class="container mx-auto px-6 py-4 flex items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center">
                        <i class="fa fa-book text-primary text-xl"></i>
                    </div>
                    <div>
                        <h1 class="text-xl font-bold text-gray-900">法硕备考管理系统</h1>
                        <p class="text-sm text-secondary">记录每日复习打卡、学习记录、考点总结，法律硕士备考专用</p>
                    </div>
                </div>
                <div class="hidden md:flex items-center gap-6">
                    <span id="current-date" class="text-secondary"></span>
                    <span class="px-4 py-1.5 bg-primary/10 text-primary rounded-full text-sm" id="total-days">备考打卡天数：0</span>
                    <button class="btn-outline text-sm">切换深色模式</button>
                </div>
            </div>
        </header>

        <div class="flex flex-1 container mx-auto px-6 py-8 gap-8 flex-col lg:flex-row">
            <!-- 左侧侧边栏 轻量化圆角卡片 -->
            <aside class="w-full lg:w-64 bg-cardBg rounded-2xl card-shadow-soft p-5 h-fit">
                <h3 class="text-sm font-semibold text-secondary mb-4 px-2">功能导航</h3>
                <nav class="space-y-2">
                    <button class="nav-btn w-full text-left flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-50 transition-all nav-active" data-target="dashboard">
                        <i class="fa fa-home w-5 text-secondary"></i>
                        <span>备考数据概览</span>
                    </button>
                    <button class="nav-btn w-full text-left flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-50 transition-all" data-target="checkin">
                        <i class="fa fa-calendar-check-o w-5 text-secondary"></i>
                        <span>每日复习打卡</span>
                    </button>
                    <button class="nav-btn w-full text-left flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-50 transition-all" data-target="plans">
                        <i class="fa fa-tasks w-5 text-secondary"></i>
                        <span>法硕复习计划</span>
                    </button>
                    <button class="nav-btn w-full text-left flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-50 transition-all" data-target="overall-plans">
                        <i class="fa fa-calendar w-5 text-secondary"></i>
                        <span>总体复习规划</span>
                    </button>
                    <button class="nav-btn w-full text-left flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-50 transition-all" data-target="records">
                        <i class="fa fa-book w-5 text-secondary"></i>
                        <span>每日复习记录</span>
                    </button>
                    <button class="nav-btn w-full text-left flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-50 transition-all" data-target="english-words">
                        <i class="fa fa-language w-5 text-secondary"></i>
                        <span>英语词汇学习</span>
                    </button>
                    <button class="nav-btn w-full text-left flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-50 transition-all" data-target="keywords">
                        <i class="fa fa-star w-5 text-secondary"></i>
                        <span>五科核心考点总结</span>
                    </button>
                </nav>
            </aside>

            <main class="flex-1 space-y-8">
                <!-- 首页仪表盘（完全对标参考图双栏布局：今日数据 + 热力日历） -->
                <section id="dashboard" class="block space-y-6">
                    <!-- 顶部统计卡片行 -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                        <div class="task-card bg-cardBg">
                            <div class="flex items-center justify-between">
                                <div>
                                    <h3 class="text-secondary text-sm">累计复习打卡天数</h3>
                                    <p class="text-3xl font-bold text-gray-900 mt-2" id="stat-checkin">0</p>
                                </div>
                                <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center">
                                    <i class="fa fa-calendar text-primary"></i>
                                </div>
                            </div>
                        </div>
                        <div class="task-card bg-cardBg">
                            <div class="flex items-center justify-between">
                                <div>
                                    <h3 class="text-secondary text-sm">已完成复习任务数</h3>
                                    <p class="text-3xl font-bold text-gray-900 mt-2" id="stat-tasks">0</p>
                                </div>
                                <div class="w-10 h-10 rounded-xl bg-success/10 flex items-center justify-center">
                                    <i class="fa fa-check text-success"></i>
                                </div>
                            </div>
                        </div>
                        <div class="task-card bg-cardBg">
                            <div class="flex items-center justify-between">
                                <div>
                                    <h3 class="text-secondary text-sm">总复习时长(小时)</h3>
                                    <p class="text-3xl font-bold text-gray-900 mt-2" id="stat-hours">0</p>
                                </div>
                                <div class="w-10 h-10 rounded-xl bg-warning/10 flex items-center justify-center">
                                    <i class="fa fa-clock-o text-warning"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 复刻原图核心布局：今日概览 + 热力日历双栏 -->
                    <div class="grid grid-cols-1 xl:grid-cols-[1.3fr_0.7fr] gap-6">
                        <!-- 左侧：今日概览 任务卡片区域 -->
                        <div class="task-card bg-cardBg p-6">
                            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-3">
                                <div>
                                    <h2 class="text-xl font-bold text-gray-900">今日概览</h2>
                                    <p class="text-secondary text-sm mt-1">查看今日所有复习待办，完成后自动统计进度</p>
                                </div>
                                <button id="jump-to-todo-btn" type="button" class="btn-primary text-sm">
                                    <i class="fa fa-plus mr-1"></i> 添加今日任务
                                </button>
                            </div>
                            <div id="dashboard-todo-preview" class="grid grid-cols-1 sm:grid-cols-2 gap-4"></div>
                        </div>

                        <!-- 右侧：热力日历模块（参考图右侧热力图） -->
                        <div class="task-card bg-cardBg p-6">
                            <div class="flex items-center justify-between mb-4">
                                <h3 class="font-semibold text-gray-900">复习热力日历</h3>
                                <span class="text-xs text-secondary">最近打卡活跃度</span>
                            </div>
                            <div class="bg-light rounded-xl p-4 min-h-[280px] flex items-center justify-center">
                                <div id="daily-entries" class="w-full space-y-2"></div>
                            </div>
                        </div>
                    </div>

                    <!-- 考研倒计时横幅 -->
                    <div class="bg-gradient-to-r from-primary/90 to-blue-400 rounded-3xl p-6 text-white card-shadow">
                        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
                            <div>
                                <p class="text-sm opacity-90">2026法律硕士考研倒计时</p>
                                <h3 class="text-2xl font-bold mt-1">距离初试还有</h3>
                            </div>
                            <div id="exam-countdown" class="flex flex-wrap gap-4 text-center"></div>
                        </div>
                    </div>

                    <!-- 月度完整日历 -->
                    <div class="task-card bg-cardBg p-6">
                        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mb-6">
                            <div>
                                <h2 class="text-lg font-bold text-gray-900">月度复习日历</h2>
                                <p class="text-secondary text-sm mt-1">点击日期可查看当日待办、总体规划和复习记录</p>
                            </div>
                            <div class="flex items-center gap-3">
                                <button id="prev-month" type="button" class="btn-outline text-sm">
                                    <i class="fa fa-chevron-left"></i>
                                </button>
                                <div id="calendar-title" class="min-w-[140px] text-center font-semibold text-gray-900"></div>
                                <button id="next-month" type="button" class="btn-outline text-sm">
                                    <i class="fa fa-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                        <div id="calendar-grid" class="overflow-x-auto"></div>
                    </div>
                </section>

                <!-- 每日复习打卡页面（表单轻量化+卡片待办） -->
                <section id="checkin" class="hidden space-y-6">
                    <div class="task-card bg-cardBg p-6">
                        <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-6">
                            <div>
                                <h2 class="text-lg font-bold flex items-center gap-2 text-gray-900">
                                    <i class="fa fa-calendar-check-o text-primary"></i>今日待办清单
                                </h2>
                                <p class="text-secondary text-sm mt-1">把每日复习任务拆成待办，勾选完成后自动汇总完成情况。</p>
                            </div>
                            <div class="px-4 py-3 rounded-xl bg-primary/10 text-primary text-sm w-fit">
                                完成情况会按日期自动记录热力日历
                            </div>
                        </div>
                        <!-- 添加任务表单 -->
                        <form id="checkin-form" class="space-y-5 mb-8">
                            <div class="grid grid-cols-1 md:grid-cols-[1.2fr_0.8fr] gap-4">
                                <div>
                                    <label class="block text-gray-700 mb-2 text-sm font-medium">任务日期</label>
                                    <input type="date" id="todo-date" class="input-base" required>
                                </div>
                                <div>
                                    <label class="block text-gray-700 mb-2 text-sm font-medium">任务内容</label>
                                    <input type="text" id="todo-title" class="input-base" placeholder="例如：背诵刑法分则" required>
                                </div>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-gray-700 mb-2 text-sm font-medium">关联复习计划</label>
                                    <select id="todo-plan" class="input-base"></select>
                                </div>
                                <div>
                                    <label class="block text-gray-700 mb-2 text-sm font-medium">完成进度(次)</label>
                                    <input type="number" id="todo-progress" min="1" value="1" class="input-base" required>
                                </div>
                            </div>
                            <div>
                                <label class="block text-gray-700 mb-2 text-sm font-medium">备注</label>
                                <textarea id="todo-note" rows="2" class="input-base" placeholder="可选：章节、目标、预计时长"></textarea>
                            </div>
                            <button type="submit" class="btn-primary flex items-center gap-2 w-fit">
                                <i class="fa fa-plus"></i>添加今日任务
                            </button>
                        </form>
                        <!-- 双栏：今日待办 + 完成统计 -->
                        <div class="grid grid-cols-1 xl:grid-cols-[1.3fr_0.7fr] gap-6">
                            <div class="bg-light rounded-2xl p-5">
                                <div class="flex items-center justify-between mb-4">
                                    <h3 class="font-semibold text-gray-900">今日待办列表</h3>
                                    <span id="todo-summary" class="text-secondary text-sm"></span>
                                </div>
                                <div id="todo-list" class="space-y-3"></div>
                            </div>
                            <div class="bg-light rounded-2xl p-5">
                                <h3 class="font-semibold text-gray-900 mb-4">近7天完成汇总</h3>
                                <div id="todo-history" class="space-y-3"></div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- 法硕复习计划页面 -->
                <section id="plans" class="hidden space-y-6">
                    <div class="task-card bg-cardBg p-6">
                        <h2 class="text-lg font-bold mb-6 flex items-center gap-2 text-gray-900">
                            <i class="fa fa-tasks text-primary"></i>法硕分科目复习计划管理
                        </h2>
                        <form id="plan-form" class="space-y-5 mb-8">
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                <div>
                                    <label class="block text-gray-700 mb-2 text-sm font-medium">复习任务名称</label>
                                    <input type="text" id="plan-name" class="input-base" placeholder="例：刑法分则财产犯罪背诵、民法物权真题训练" required>
                                </div>
                                <div>
                                    <label class="block text-gray-700 mb-2 text-sm font-medium">所属考试科目</label>
                                    <select id="plan-subject" class="input-base">
                                        <option value="xingfa">刑法</option>
                                        <option value="minfa">民法</option>
                                        <option value="fali">法理学</option>
                                        <option value="xianfa">宪法</option>
                                        <option value="fazhishi">法制史</option>
                                        <option value="zhengzhi">政治</option>
                                        <option value="yingyu">英语</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-gray-700 mb-2 text-sm font-medium">总目标进度(次)</label>
                                    <input type="number" min="1" id="plan-progress" class="input-base" placeholder="例：10" required>
                                </div>
                            </div>
                            <button type="submit" class="btn-primary w-fit">
                                添加新复习任务
                            </button>
                        </form>
                        <h3 class="font-semibold mb-4 text-gray-900">全部复习任务清单</h3>
                        <div id="plan-list" class="space-y-4 max-h-[500px] overflow-y-auto pr-2"></div>
                    </div>
                </section>

                <!-- 总体复习规划 -->
                <section id="overall-plans" class="hidden space-y-6">
                    <div class="task-card bg-cardBg p-6">
                        <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-6">
                            <div>
                                <h2 class="text-lg font-bold flex items-center gap-2 text-gray-900">
                                    <i class="fa fa-calendar text-primary"></i>总体复习规划
                                </h2>
                                <p class="text-secondary text-sm mt-1">记录阶段性目标，并根据完成时间自动生成时间线。</p>
                            </div>
                        </div>
                        <form id="overall-plan-form" class="grid grid-cols-1 md:grid-cols-[1.2fr_1fr_0.8fr_0.8fr_auto] gap-4 mb-8">
                            <div>
                                <label class="block text-gray-700 mb-2 text-sm font-medium">规划标题</label>
                                <input type="text" id="overall-plan-title" class="input-base" placeholder="例如：第一轮刑法背诵完成" required>
                            </div>
                            <div>
                                <label class="block text-gray-700 mb-2 text-sm font-medium">规划内容</label>
                                <input type="text" id="overall-plan-detail" class="input-base" placeholder="例如：完成分则各章重点背诵" required>
                            </div>
                            <div>
                                <label class="block text-gray-700 mb-2 text-sm font-medium">开始时间</label>
                                <input type="datetime-local" id="overall-plan-start" class="input-base">
                            </div>
                            <div>
                                <label class="block text-gray-700 mb-2 text-sm font-medium">完成日期</label>
                                <input type="date" id="overall-plan-complete-date" class="input-base">
                            </div>
                            <div class="flex items-end">
                                <button type="submit" class="btn-primary w-full">
                                    添加规划
                                </button>
                            </div>
                        </form>
                        <div class="mt-10">
                            <h3 class="font-semibold mb-4 text-gray-900">规划月视图</h3>
                            <div class="flex items-center justify-between mb-4">
                                <button type="button" id="overall-plan-prev-month" class="btn-outline text-sm">
                                    <i class="fa fa-chevron-left"></i>
                                </button>
                                <div id="overall-plan-month-label" class="font-semibold text-gray-900 text-lg"></div>
                                <button type="button" id="overall-plan-next-month" class="btn-outline text-sm">
                                    <i class="fa fa-chevron-right"></i>
                                </button>
                            </div>
                            <div id="overall-plan-month-view" class="overflow-x-auto"></div>
                        </div>
                        <div class="mt-10">
                            <h3 class="font-semibold mb-4 text-gray-900">当前规划列表</h3>
                            <div id="overall-plan-list" class="space-y-3"></div>
                        </div>
                    </div>
                </section>

                <!-- 复习记录页面 -->
                <section id="records" class="hidden space-y-6">
                    <div class="task-card bg-cardBg p-6">
                        <h2 class="text-lg font-bold mb-6 flex items-center gap-2 text-gray-900">
                            <i class="fa fa-book text-primary"></i>法硕精细复习复盘记录
                        </h2>
                        <form id="record-form" class="space-y-5">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-gray-700 mb-2 text-sm font-medium">复习日期</label>
                                    <input type="date" id="record-date" class="input-base" required>
                                </div>
                                <div>
                                    <label class="block text-gray-700 mb-2 text-sm font-medium">分类/科目</label>
                                    <select id="record-subject" class="input-base">
                                        <option value="刑法">刑法</option>
                                        <option value="民法">民法</option>
                                        <option value="法理学">法理学</option>
                                        <option value="宪法">宪法</option>
                                        <option value="法制史">法制史</option>
                                        <option value="政治">政治</option>
                                        <option value="英语">英语</option>
                                        <option value="真题刷题">真题刷题</option>
                                        <option value="主观题背诵">主观题背诵</option>
                                    </select>
                                </div>
                            </div>
                            <div>
                                <label class="block text-gray-700 mb-2 text-sm font-medium">当日详细学习复盘</label>
                                <textarea id="record-detail" rows="4" class="input-base" placeholder="详细记录今日背诵考点、错题、易混淆概念、主观题答题思路、薄弱章节" required></textarea>
                            </div>
                            <button type="submit" class="btn-primary w-fit">
                                保存复习复盘记录
                            </button>
                        </form>
                        <div class="mt-10">
                            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3 mb-4">
                                <h3 class="font-semibold text-gray-900">历史复习复盘存档</h3>
                                <select id="record-filter" class="input-base w-full md:w-48">
                                    <option value="all">全部分类</option>
                                    <option value="刑法">刑法</option>
                                    <option value="民法">民法</option>
                                    <option value="法理学">法理学</option>
                                    <option value="宪法">宪法</option>
                                    <option value="法制史">法制史</option>
                                    <option value="政治">政治</option>
                                    <option value="英语">英语</option>
                                    <option value="真题刷题">真题刷题</option>
                                    <option value="主观题背诵">主观题背诵</option>
                                </select>
                            </div>
