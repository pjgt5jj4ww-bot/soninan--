        function renderTodoHistory() {
            const todos = readTodos();
            const grouped = todos.reduce((result, item) => {
                if (!result[item.date]) {
                    result[item.date] = [];
                }
                result[item.date].push(item);
                return result;
            }, {});
            const history = document.getElementById('todo-history');
            const dates = Object.keys(grouped).sort().slice(-7).reverse();

            if (!dates.length) {
                history.innerHTML = '<div class="text-secondary text-sm">暂无完成汇总记录。</div>';
                return;
            }

            history.innerHTML = dates.map(date => {
                const items = grouped[date];
                const completedCount = items.filter(item => item.completed).length;
                const total = items.length;
                const percent = total ? Math.round((completedCount / total) * 100) : 0;
                return `
                    <div class="rounded-xl border border-gray-200 bg-cardBg p-4 task-card">
                        <div class="flex items-center justify-between text-sm mb-2">
                            <span class="font-medium text-gray-800">${date}</span>
