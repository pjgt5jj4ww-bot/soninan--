        window.toggleOverallPlan = function(id) {
            const plans = readOverallPlans();
            const updated = plans.map(item => {
                if (item.id !== id) {
                    return item;
                }
                const willComplete = !item.completed;
                const nextItem = { ...item, completed: willComplete, completedAt: willComplete ? todayString : '' };
                if (item.linkedPlanId) {
                    const linkedPlans = Storage.get('plans');
                    const targetPlan = linkedPlans.find(plan => plan.id === item.linkedPlanId);
                    if (targetPlan) {
                        const nextTarget = getPlanTarget(targetPlan);
                        const nextCompletedUnits = willComplete ? Math.min(nextTarget, Math.max(1, getPlanCompletedUnits(targetPlan))) : 0;
                        const nextProgress = Math.min(100, Math.round((nextCompletedUnits / nextTarget) * 100));
                        Storage.set('plans', linkedPlans.map(plan => plan.id === item.linkedPlanId ? { ...plan, completedUnits: nextCompletedUnits, progress: nextProgress } : plan));
                    }
                }
                return nextItem;
            });
            saveOverallPlans(updated);
            renderOverallPlans();
            renderOverallPlanMonthView();
            renderPlanList();
            updateStats();
        };

