    <!-- 下方JS逻辑完全保留，无任何修改，所有功能100%原样生效 -->
    <script>
        const subjectColors = {
            xingfa: '#DC2626',
            minfa: '#2563EB',
            fali: '#D97706',
            xianfa: '#059669',
            fazhishi: '#7C3AED',
